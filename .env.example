# Frontend (Expo)
# Set to your backend base URL (the app will call /api/auth/...)
# Examples:
#   http://<your-ip>:8080
#   https://your-deployed-backend.com
EXPO_PUBLIC_API_URL=http://localhost:8080

# Backend (Express)
PORT=8080
MONGO_URI=mongodb://localhost:27017/productiv
JWT_SECRET=change-me
BREVO_API_KEY=change-me
BREVO_SENDER_EMAIL=talknow@example.com
BREVO_SENDER_NAME=TalkNow
